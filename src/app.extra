/* ─── Voter List Card ─── */
.voter-list-card {
  padding: 20px 16px;
}

.voter-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
  max-height: 320px;
  overflow-y: auto;
}

.voter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 10px;
  background: rgba(240, 235, 220, 0.7);
  border-left: 3px solid #ccc;
  font-size: clamp(11px, 3vw, 13px);
  flex-wrap: wrap;
}

.voter-red   { border-left-color: #e53935; }
.voter-green { border-left-color: #43a047; }

.voter-name {
  font-weight: 700;
  color: #3a4a32;
  min-width: 80px;
}

.voter-color {
  font-weight: 800;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
}

.voter-meta {
  color: #7a8c6e;
  font-size: 11px;
  font-style: italic;
}