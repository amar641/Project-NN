/* ── APPEND THESE TO THE BOTTOM OF src/App.css ── */

/* ─── Prediction Banner ─── */
.prediction-banner {
  border-radius: 12px;
  padding: 10px 18px;
  font-size: clamp(13px, 3.5vw, 15px);
  font-weight: 600;
  margin: 0 0 12px;
  letter-spacing: 0.3px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  flex-wrap: wrap;
}

.prediction-red {
  background: rgba(253, 232, 232, 0.85);
  border: 1.5px solid #e57373;
  color: #b71c1c;
}

.prediction-green {
  background: rgba(232, 245, 233, 0.85);
  border: 1.5px solid #66bb6a;
  color: #1b5e20;
}

.prediction-result {
  font-weight: 400;
  opacity: 0.85;
}

/* ─── Voter count strip ─── */
.voter-count {
  font-size: clamp(11px, 3vw, 13px);
  color: #6b7a5e;
  margin: 0 0 12px;
}

.agent-fill {
  color: #b07d2e;
  font-style: italic;
}

/* ─── Metrics card ─── */
.metrics-card {
  padding: 24px 20px;
}

